# Pulse Trading Platform Environment Configuration

# Basic Configuration
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DATABASE_URL=postgresql://pulse:pulse_password@localhost:5432/pulse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Satellite Data API Keys
PLANET_API_KEY=your_planet_api_key_here
MAXAR_API_KEY=your_maxar_api_key_here
LANDSAT_API_KEY=your_landsat_api_key_here
GOOGLE_EARTH_ENGINE_KEY=path_to_service_account_json

# Financial Data API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
IEX_CLOUD_API_KEY=your_iex_cloud_key_here
POLYGON_API_KEY=your_polygon_key_here
QUANDL_API_KEY=your_quandl_key_here

# Trading Configuration
TRADING_MODE=paper
MAX_POSITION_SIZE=0.02
MAX_SECTOR_EXPOSURE=0.10
STOP_LOSS_MULTIPLIER=2.0
MAX_DAILY_LOSS=0.01

# ML Model Configuration
GPU_ENABLED=true
BATCH_SIZE=16

# Monitoring
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here
PROMETHEUS_PORT=9090

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256